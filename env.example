import React, { useState, useEffect } from 'react'
import { supabase } from '../lib/supabase'
import { Plus, Trash2 } from 'lucide-react'

// ---- USUÁRIOS ----
export function Usuarios() {
  const [usuarios, setUsuarios] = useState([])
  const [escritorioId, setEscritorioId] = useState(null)
  const [showModal, setShowModal] = useState(false)
  const [form, setForm] = useState({ nome: '', email: '', senha: '', nivel: 'contador' })
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState('')

  useEffect(() => {
    async function load() {
      const { data: u } = await supabase.from('usuarios')
        .select('escritorio_id').eq('id', (await supabase.auth.getUser()).data.user.id).single()
      if (!u) return
      setEscritorioId(u.escritorio_id)
      const { data } = await supabase.from('usuarios').select('*')
        .eq('escritorio_id', u.escritorio_id).order('nome')
      setUsuarios(data || [])
    }
    load()
  }, [])

  async function criarUsuario() {
    if (!form.nome || !form.email || !form.senha) { setError('Preencha todos os campos.'); return }
    setLoading(true); setError('')
    const { data: authData, error: ae } = await supabase.auth.admin
      ? { data: null, error: { message: 'Use signup' } }
      : await supabase.auth.signUp({ email: form.email, password: form.senha })
    // Note: in production use admin API or invite flow
    const { data: signUp, error: signUpError } = await supabase.auth.signUp({
      email: form.email, password: form.senha,
      options: { data: { nome: form.nome } }
    })
    if (signUpError) { setError(signUpError.message); setLoading(false); return }
    const uid = signUp.user?.id
    if (uid) {
      await supabase.from('usuarios').insert({
        id: uid, escritorio_id: escritorioId,
        nome: form.nome, email: form.email, nivel: form.nivel
      })
      const { data } = await supabase.from('usuarios').select('*')
        .eq('escritorio_id', escritorioId).order('nome')
      setUsuarios(data || [])
    }
    setShowModal(false); setForm({ nome:'', email:'', senha:'', nivel:'contador' }); setLoading(false)
  }

  const nivelLabel = { admin: 'Admin', contador: 'Contador', visualizador: 'Visualizador' }
  const nivelColor = { admin: 'badge-lr', contador: 'badge-sn', visualizador: 'badge-outro' }

  return (
    <>
      <div className="page-header">
        <div><div className="page-title">Usuários</div><div className="page-subtitle">Acesso ao sistema</div></div>
        <button className="btn btn-primary" onClick={()=>setShowModal(true)}><Plus size={14}/> Novo usuário</button>
      </div>
      <div className="page-content">
        <div className="card">
          <div className="table-wrap">
            <table>
              <thead><tr><th>Nome</th><th>E-mail</th><th style={{width:100}}>Nível</th><th style={{width:80}}>Status</th></tr></thead>
              <tbody>
                {usuarios.map(u => (
                  <tr key={u.id}>
                    <td style={{fontWeight:500}}>{u.nome}</td>
                    <td style={{fontSize:12, color:'var(--text-muted)'}}>{u.email}</td>
                    <td><span className={`badge ${nivelColor[u.nivel]}`}>{nivelLabel[u.nivel]}</span></td>
                    <td><span className={`badge ${u.ativo?'badge-ativa':'badge-outro'}`}>{u.ativo?'Ativo':'Inativo'}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      {showModal && (
        <div className="modal-overlay" onClick={e=>e.target===e.currentTarget&&setShowModal(false)}>
          <div className="modal">
            <div className="modal-header">
              <h3>Novo usuário</h3>
              <button className="btn btn-sm" onClick={()=>setShowModal(false)}>Fechar</button>
            </div>
            <div className="modal-body">
              <div className="field"><label>Nome completo *</label><input value={form.nome} onChange={e=>setForm(f=>({...f,nome:e.target.value}))} placeholder="Nome"/></div>
              <div className="field"><label>E-mail *</label><input type="email" value={form.email} onChange={e=>setForm(f=>({...f,email:e.target.value}))} placeholder="usuario@escritorio.com.br"/></div>
              <div className="field-row field-row-2">
                <div className="field"><label>Senha *</label><input type="password" value={form.senha} onChange={e=>setForm(f=>({...f,senha:e.target.value}))} placeholder="mínimo 6 caracteres"/></div>
                <div className="field"><label>Nível de acesso</label>
                  <select value={form.nivel} onChange={e=>setForm(f=>({...f,nivel:e.target.value}))}>
                    <option value="admin">Admin</option>
                    <option value="contador">Contador</option>
                    <option value="visualizador">Visualizador</option>
                  </select>
                </div>
              </div>
              {error && <div className="error-msg">{error}</div>}
            </div>
            <div className="modal-footer">
              <button className="btn" onClick={()=>setShowModal(false)}>Cancelar</button>
              <button className="btn btn-primary" onClick={criarUsuario} disabled={loading}>{loading?'Criando...':'Criar usuário'}</button>
            </div>
          </div>
        </div>
      )}
    </>
  )
}

// ---- COMPETÊNCIAS ----
export function Competencias() {
  const [comps, setComps] = useState([])
  const [escritorioId, setEscritorioId] = useState(null)
  const [showModal, setShowModal] = useState(false)
  const [form, setForm] = useState({ ano: '', data_inicio: '', data_fim: '', status: 'aberta' })

  useEffect(() => {
    async function load() {
      const { data: u } = await supabase.from('usuarios')
        .select('escritorio_id').eq('id', (await supabase.auth.getUser()).data.user.id).single()
      if (!u) return
      setEscritorioId(u.escritorio_id)
      const { data } = await supabase.from('competencias').select('*')
        .eq('escritorio_id', u.escritorio_id).order('ano', {ascending:false})
      setComps(data || [])
    }
    load()
  }, [])

  async function criar() {
    if (!form.ano) return
    const { data } = await supabase.from('competencias').insert({
      escritorio_id: escritorioId, ano: parseInt(form.ano),
      data_inicio: form.data_inicio || `${form.ano}-01-01`,
      data_fim: form.data_fim || `${form.ano}-12-31`,
      status: form.status
    }).select().single()
    if (data) { setComps(c => [data, ...c]); setShowModal(false); setForm({ano:'',data_inicio:'',data_fim:'',status:'aberta'}) }
  }

  async function encerrar(id) {
    await supabase.from('competencias').update({status:'encerrada'}).eq('id',id)
    setComps(c => c.map(x => x.id===id ? {...x,status:'encerrada'} : x))
  }

  const statusBadge = s => s==='aberta'
    ? <span className="badge badge-ativa">Aberta</span>
    : s==='planejamento'
    ? <span className="badge badge-distrato">Planejamento</span>
    : <span className="badge badge-outro">Encerrada</span>

  return (
    <>
      <div className="page-header">
        <div><div className="page-title">Competências</div><div className="page-subtitle">Anos fiscais</div></div>
        <button className="btn btn-primary" onClick={()=>setShowModal(true)}><Plus size={14}/> Criar ano</button>
      </div>
      <div className="page-content">
        <div className="card">
          <div className="table-wrap">
            <table>
              <thead><tr><th style={{width:80}}>Ano</th><th>Início</th><th>Fim</th><th style={{width:120}}>Status</th><th style={{width:100}}></th></tr></thead>
              <tbody>
                {comps.map(c => (
                  <tr key={c.id}>
                    <td style={{fontWeight:600, fontSize:15}}>{c.ano}</td>
                    <td style={{fontSize:13}}>{c.data_inicio ? new Date(c.data_inicio).toLocaleDateString('pt-BR') : '—'}</td>
                    <td style={{fontSize:13}}>{c.data_fim ? new Date(c.data_fim).toLocaleDateString('pt-BR') : '—'}</td>
                    <td>{statusBadge(c.status)}</td>
                    <td>{c.status==='aberta' && <button className="btn btn-sm" onClick={()=>encerrar(c.id)}>Encerrar</button>}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      {showModal && (
        <div className="modal-overlay" onClick={e=>e.target===e.currentTarget&&setShowModal(false)}>
          <div className="modal">
            <div className="modal-header"><h3>Nova competência</h3><button className="btn btn-sm" onClick={()=>setShowModal(false)}>Fechar</button></div>
            <div className="modal-body">
              <div className="field-row field-row-2">
                <div className="field"><label>Ano fiscal *</label><input value={form.ano} onChange={e=>setForm(f=>({...f,ano:e.target.value}))} placeholder="2026"/></div>
                <div className="field"><label>Status inicial</label>
                  <select value={form.status} onChange={e=>setForm(f=>({...f,status:e.target.value}))}>
                    <option value="aberta">Aberta</option><option value="planejamento">Planejamento</option>
                  </select>
                </div>
              </div>
              <div className="field-row field-row-2">
                <div className="field"><label>Data início</label><input type="date" value={form.data_inicio} onChange={e=>setForm(f=>({...f,data_inicio:e.target.value}))}/></div>
                <div className="field"><label>Data fim</label><input type="date" value={form.data_fim} onChange={e=>setForm(f=>({...f,data_fim:e.target.value}))}/></div>
              </div>
            </div>
            <div className="modal-footer">
              <button className="btn" onClick={()=>setShowModal(false)}>Cancelar</button>
              <button className="btn btn-primary" onClick={criar}>Criar</button>
            </div>
          </div>
        </div>
      )}
    </>
  )
}

// ---- GRUPOS / REGIMES ----
export function Grupos() {
  const [grupos, setGrupos] = useState([])
  const [escritorioId, setEscritorioId] = useState(null)
  const [showModal, setShowModal] = useState(false)
  const [form, setForm] = useState({ nome: '', descricao: '' })

  useEffect(() => {
    async function load() {
      const { data: u } = await supabase.from('usuarios')
        .select('escritorio_id').eq('id', (await supabase.auth.getUser()).data.user.id).single()
      if (!u) return
      setEscritorioId(u.escritorio_id)
      const { data } = await supabase.from('grupos').select('*')
        .eq('escritorio_id', u.escritorio_id).order('ordem')
      setGrupos(data || [])
    }
    load()
  }, [])

  async function criar() {
    if (!form.nome) return
    const { data } = await supabase.from('grupos').insert({
      escritorio_id: escritorioId, nome: form.nome, descricao: form.descricao,
      ordem: grupos.length + 1
    }).select().single()
    if (data) { setGrupos(g => [...g, data]); setShowModal(false); setForm({nome:'',descricao:''}) }
  }

  async function remover(id) {
    if (!window.confirm('Remover este grupo? Clientes vinculados perderão o regime.')) return
    await supabase.from('grupos').delete().eq('id', id)
    setGrupos(g => g.filter(x=>x.id!==id))
  }

  const corBadge = nome => {
    if (nome?.includes('Real')) return 'badge-lr'
    if (nome?.includes('Presumido')) return 'badge-lp'
    if (nome?.includes('Simples')) return 'badge-sn'
    return 'badge-outro'
  }

  return (
    <>
      <div className="page-header">
        <div><div className="page-title">Grupos / Regimes</div><div className="page-subtitle">Classificação tributária</div></div>
        <button className="btn btn-primary" onClick={()=>setShowModal(true)}><Plus size={14}/> Novo grupo</button>
      </div>
      <div className="page-content">
        <div className="card">
          <div className="table-wrap">
            <table>
              <thead><tr><th>Regime</th><th>Descrição</th><th style={{width:80}}></th></tr></thead>
              <tbody>
                {grupos.map(g => (
                  <tr key={g.id}>
                    <td><span className={`badge ${corBadge(g.nome)}`}>{g.nome}</span></td>
                    <td style={{fontSize:13, color:'var(--text-muted)'}}>{g.descricao}</td>
                    <td><button className="btn btn-sm btn-danger" onClick={()=>remover(g.id)}><Trash2 size={12}/></button></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      {showModal && (
        <div className="modal-overlay" onClick={e=>e.target===e.currentTarget&&setShowModal(false)}>
          <div className="modal">
            <div className="modal-header"><h3>Novo grupo / regime</h3><button className="btn btn-sm" onClick={()=>setShowModal(false)}>Fechar</button></div>
            <div className="modal-body">
              <div className="field"><label>Nome do regime *</label><input value={form.nome} onChange={e=>setForm(f=>({...f,nome:e.target.value}))} placeholder="Ex: Lucro Arbitrado"/></div>
              <div className="field"><label>Descrição</label><textarea value={form.descricao} onChange={e=>setForm(f=>({...f,descricao:e.target.value}))} placeholder="Descreva brevemente..."/></div>
            </div>
            <div className="modal-footer">
              <button className="btn" onClick={()=>setShowModal(false)}>Cancelar</button>
              <button className="btn btn-primary" onClick={criar}>Criar grupo</button>
            </div>
          </div>
        </div>
      )}
    </>
  )
}

export default Usuarios
